# Disgaea DS Manager — macOS 14 Build
CXX := clang++
CXXSTD := c++20

# Auto-detect Homebrew prefix (Apple Silicon or Intel)
BREW_PREFIX := $(shell brew --prefix 2>/dev/null)
QT_PREFIX   := $(shell brew --prefix qt@6 2>/dev/null || echo $(BREW_PREFIX)/opt/qt@6)

# Use pkg-config from Qt6 to get exact flags (fallback to manual)
PKG_CONFIG := $(QT_PREFIX)/bin/qt-cmake  # not used directly
QT_INC     := $(shell PKG_CONFIG_PATH=$(QT_PREFIX)/lib/pkgconfig pkg-config --cflags Qt6Widgets 2>/dev/null)
QT_LIB     := $(shell PKG_CONFIG_PATH=$(QT_PREFIX)/lib/pkgconfig pkg-config --libs Qt6Widgets 2>/dev/null)

# Fallback if pkg-config fails
ifeq ($(QT_INC),)
QT_INC := -F$(QT_PREFIX)/lib \
          -I$(QT_PREFIX)/include \
          -I$(QT_PREFIX)/include/QtWidgets \
          -I$(QT_PREFIX)/include/QtCore \
          -I$(QT_PREFIX)/include/QtGui
endif

ifeq ($(QT_LIB),)
QT_LIB := -F$(QT_PREFIX)/lib \
          -framework QtWidgets -framework QtCore -framework QtGui \
          -Wl,-rpath,$(QT_PREFIX)/lib
endif

CXXFLAGS := -std=$(CXXSTD) -O2 -Wall -Wextra $(QT_INC) -Iinclude
LDFLAGS  := $(QT_LIB)

BUILD := build
TARGET := DisgaeaDSManager

SRC := src2/main.cpp \
      src2/formats.cpp \
      src2/reader.cpp \
      src2/writer.cpp \
      src2/commands.cpp \
      src2/document_manager.cpp \
      src2/extraction.cpp \
      src2/folder_import.cpp \
      src2/dialog_service.cpp \
      src2/main_window.cpp

OBJS := $(addprefix $(BUILD)/, $(SRC:.cpp=.o))
MOC_SRC := $(BUILD)/moc_main_window.cpp
OBJS    += $(MOC_SRC:.cpp=.o)

MOC := $(QT_PREFIX)/bin/moc

.PHONY: all clean run app

all: $(TARGET)

$(BUILD)/moc_%.cpp: include/%.hpp | $(BUILD)
	@mkdir -p $(dir $@)
	$(MOC) $< -o $@

$(BUILD)/%.o: %.cpp | $(BUILD)
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(BUILD)/moc_main_window.o: $(BUILD)/moc_main_window.cpp | $(BUILD)
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(TARGET): $(OBJS)
	$(CXX) $(OBJS) $(LDFLAGS) -o $(TARGET)

$(BUILD):
	mkdir -p $(BUILD)/src

clean:
	rm -rf $(BUILD) $(TARGET) $(TARGET).app

run: all
	./$(TARGET)

app: $(TARGET)
	mkdir -p $(TARGET).app/Contents/MacOS
	cp $(TARGET) $(TARGET).app/Contents/MacOS/
	$(QT_PREFIX)/bin/macdeployqt $(TARGET).app

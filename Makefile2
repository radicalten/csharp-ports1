# Disgaea DS Manager — macOS 14 Build
CXX      := clang++
CXXSTD   := c++20
QT_PREFIX := $(shell brew --prefix qt@6 2>/dev/null || echo /opt/homebrew/opt/qt@6)
MOC      := $(QT_PREFIX)/bin/moc

CXXFLAGS := -std=$(CXXSTD) -O2 -Wall -Wextra \
            -F$(QT_PREFIX)/lib \
            -Iinclude \
            -I$(QT_PREFIX)/include \
            -I$(QT_PREFIX)/include/QtWidgets \
            -I$(QT_PREFIX)/include/QtCore \
            -I$(QT_PREFIX)/include/QtGui

LDFLAGS  := -F$(QT_PREFIX)/lib \
            -framework QtWidgets -framework QtCore -framework QtGui \
            -Wl,-rpath,$(QT_PREFIX)/lib

BUILD := build
TARGET := DisgaeaDSManager

# Source files (root + src/)
SRC := src2/main.cpp \
      src2/formats.cpp \
      src2/reader.cpp \
      src2/writer.cpp \
      src2/commands.cpp \
      src2/document_manager.cpp \
      src2/extraction.cpp \
      src2/folder_import.cpp \
      src2/dialog_service.cpp \
      src2/main_window.cpp

# Object files: keep same relative dir under build/
OBJS := $(addprefix $(BUILD)/, $(SRC:.cpp=.o))

# moc-generated source from header
MOC_SRC := $(BUILD)/moc_main_window.cpp
OBJS    += $(MOC_SRC:.cpp=.o)

.PHONY: all clean run app

all: $(TARGET)

# moc step
$(BUILD)/moc_%.cpp: include/%.hpp | $(BUILD)
	@mkdir -p $(dir $@)
	$(MOC) $< -o $@

# Generic compile: build/xxx.o from xxx.cpp (works for root and src/)
$(BUILD)/%.o: %.cpp | $(BUILD)
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Compile moc output
$(BUILD)/moc_main_window.o: $(BUILD)/moc_main_window.cpp | $(BUILD)
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(TARGET): $(OBJS)
	$(CXX) $(OBJS) $(LDFLAGS) -o $(TARGET)

$(BUILD):
	mkdir -p $(BUILD)/src

clean:
	rm -rf $(BUILD) $(TARGET) $(TARGET).app

run: all
	./$(TARGET)

app: $(TARGET)
	mkdir -p $(TARGET).app/Contents/MacOS
	cp $(TARGET) $(TARGET).app/Contents/MacOS/
	$(QT_PREFIX)/bin/macdeployqt $(TARGET).app

```cpp
#include "formats.hpp"
#include <algorithm>
#include <stdexcept>

namespace dsm {

const std::vector<uint8_t> MAGIC_DSARC = {0x44,0x53,0x41,0x52,0x43,0x20,0x46,0x4C};
const std::vector<uint8_t> MAGIC_MSND  = {0x44,0x53,0x45,0x51};
const std::vector<std::string> MSND_ORDER = {".sseq", ".sbnk", ".swar"};

std::vector<uint8_t> pad_name(const std::string& n) {
    std::vector<uint8_t> out(NAME_SIZE, 0);
    size_t len = std::min(n.size(), (size_t)NAME_SIZE);
    std::copy(n.begin(), n.begin() + len, out.begin());
    return out;
}

ArchiveType detect_type(const std::vector<uint8_t>& buf) {
    if (buf.size() >= 4 && std::equal(buf.begin(), buf.begin()+4, MAGIC_MSND.begin()))
        return ArchiveType::MSND;
    if (buf.size() >= 8 && std::equal(buf.begin(), buf.begin()+8, MAGIC_DSARC.begin()))
        return ArchiveType::DSARC;
    throw std::runtime_error("Unknown archive format.");
}

std::optional<ArchiveType> detect_type_from_buffer(const std::vector<uint8_t>& data) {
    if (data.size() >= 8 && std::equal(data.begin(), data.begin()+8, MAGIC_DSARC.begin()))
        return ArchiveType::DSARC;
    if (data.size() >= 4 && std::equal(data.begin(), data.begin()+4, MAGIC_MSND.begin()))
        return ArchiveType::MSND;
    return std::nullopt;
}

MsndOffsets parse_msnd_offsets(const std::vector<uint8_t>& b) {
    if (b.size() < MSND_HEADER) throw std::runtime_error("Buffer too small for MSND header.");
    auto i32 = [&](size_t o) { return *reinterpret_cast<const int32_t*>(b.data() + o); };
    return { i32(16) - 16, i32(20), i32(24), i32(32), i32(36), i32(40) };
}

bool are_msnd_bounds_valid(size_t len, const MsndOffsets& o) {
    return o.sseq_offset >= 0 && o.sseq_size >= 0 && (size_t)(o.sseq_offset + o.sseq_size) <= len &&
           o.sbnk_offset >= 0 && o.sbnk_size >= 0 && (size_t)(o.sbnk_offset + o.sbnk_size) <= len &&
           o.swar_offset >= 0 && o.swar_size >= 0 && (size_t)(o.swar_offset + o.swar_size) <= len;
}

std::vector<uint8_t> build_msnd(const std::vector<uint8_t>& sseq,
                                const std::vector<uint8_t>& sbnk,
                                const std::vector<uint8_t>& swar,
                                const std::vector<uint8_t>& unknown) {
    for (auto& ext : MSND_ORDER) { (void)ext; }
    int sseq_off = MSND_HEADER;
    int sbnk_off = sseq_off + (int)sseq.size();
    int swar_off = sbnk_off + (int)sbnk.size();
    std::vector<uint8_t> out;
    out.reserve(MSND_HEADER + sseq.size() + sbnk.size() + swar.size());
    out.insert(out.end(), MAGIC_MSND.begin(), MAGIC_MSND.end());
    out.resize(out.size() + 12);
    auto w32 = [&](int v) { auto p = (uint8_t*)&v; out.insert(out.end(), p, p + 4); };
    w32(sseq_off + 16); w32(sbnk_off); w32(swar_off);
    w32(0); w32((int)sseq.size()); w32((int)sbnk.size()); w32((int)swar.size());
    if (unknown.size() == 4) out.insert(out.end(), unknown.begin(), unknown.end());
    else out.resize(out.size() + 4);
    out.insert(out.end(), sseq.begin(), sseq.end());
    out.insert(out.end(), sbnk.begin(), sbnk.end());
    out.insert(out.end(), swar.begin(), swar.end());
    return out;
}

std::vector<uint8_t> build_empty_msnd() {
    std::vector<uint8_t> out(MSND_HEADER, 0);
    std::copy(MAGIC_MSND.begin(), MAGIC_MSND.end(), out.begin());
    auto w32 = [&](size_t o, int v) { *reinterpret_cast<int32_t*>(out.data() + o) = v; };
    w32(16, MSND_HEADER + 16);
    w32(20, MSND_HEADER);
    w32(24, MSND_HEADER);
    return out;
}

std::vector<uint8_t> extract_msnd_unknown(const std::vector<uint8_t>& msnd) {
    if (msnd.size() < MSND_HEADER) return std::vector<uint8_t>(4, 0);
    return std::vector<uint8_t>(msnd.begin() + MSND_UNKNOWN_OFFSET,
                                msnd.begin() + MSND_UNKNOWN_OFFSET + 4);
}

void populate_msnd_children(const std::vector<uint8_t>& data, ArchiveEntryPtr parent,
                            const std::string& base_name) {
    MsndOffsets o = parse_msnd_offsets(data);
    if (!are_msnd_bounds_valid(data.size(), o)) return;
    parent->children.clear();
    auto mk = [&](const std::string& ext, int off, int sz) {
        auto e = std::make_shared<ArchiveEntry>();
        e->name = base_name + ext;
        e->size = sz;
        e->offset = off;
        e->data.assign(data.begin() + off, data.begin() + off + sz);
        parent->children.push_back(e);
    };
    mk(".sseq", o.sseq_offset, o.sseq_size);
    mk(".sbnk", o.sbnk_offset, o.sbnk_size);
    mk(".swar", o.swar_offset, o.swar_size);
}

std::vector<uint8_t> replace_chunk(const std::vector<uint8_t>& msnd,
                                   const std::string& ext,
                                   const std::vector<uint8_t>& new_data) {
    if (msnd.size() < MSND_HEADER || !std::equal(msnd.begin(), msnd.begin()+4, MAGIC_MSND.begin()))
        throw std::runtime_error("Invalid MSND buffer.");
    MsndOffsets o = parse_msnd_offsets(msnd);
    auto unk = extract_msnd_unknown(msnd);
    std::vector<uint8_t> sseq(msnd.begin()+o.sseq_offset, msnd.begin()+o.sseq_offset+o.sseq_size);
    std::vector<uint8_t> sbnk(msnd.begin()+o.sbnk_offset, msnd.begin()+o.sbnk_offset+o.sbnk_size);
    std::vector<uint8_t> swar(msnd.begin()+o.swar_offset, msnd.begin()+o.swar_offset+o.swar_size);
    std::string e = ext;
    if (e[0] != '.') e = "." + e;
    std::transform(e.begin(), e.end(), e.begin(), ::tolower);
    if (e == ".sseq") sseq = new_data;
    else if (e == ".sbnk") sbnk = new_data;
    else if (e == ".swar") swar = new_data;
    else throw std::runtime_error("Invalid chunk extension: " + ext);
    return build_msnd(sseq, sbnk, swar, unk);
}

} // namespace dsm

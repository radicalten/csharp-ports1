<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Disgaea_DS_Manager.MainWindow"
        Title="Disgaea DS Manager"
        Width="1000" Height="700"
        MinWidth="600" MinHeight="400">
  <Window.Resources>
    <SolidColorBrush x:Key="ModifiedBrush" Color="#FF8800" />
    <SolidColorBrush x:Key="DropIndicatorBrush" Color="#0078D4" />
  </Window.Resources>
  <Panel>
    <DockPanel LastChildFill="True">
      <Menu DockPanel.Dock="Top">
        <MenuItem Header="_File">
          <MenuItem x:Name="NewMenu" Header="_New..." InputGesture="Ctrl+N" />
          <MenuItem x:Name="OpenMenu" Header="_Open..." InputGesture="Ctrl+O" />
          <Separator/>
          <MenuItem x:Name="SaveMenu" Header="_Save" InputGesture="Ctrl+S" />
          <MenuItem x:Name="SaveAsMenu" Header="Save _As..." InputGesture="Ctrl+Shift+S" />
          <Separator/>
          <MenuItem x:Name="ExitMenu" Header="E_xit" InputGesture="Alt+F4" />
        </MenuItem>
        <MenuItem Header="_Edit">
          <MenuItem x:Name="UndoMenu" Header="_Undo" InputGesture="Ctrl+Z" />
          <MenuItem x:Name="RedoMenu" Header="_Redo" InputGesture="Ctrl+Y" />
          <Separator/>
          <MenuItem x:Name="SortMenu" Header="_Sort by Alphabetical Order" />
          <MenuItem x:Name="SortRecursiveMenu" Header="Sort _Recursively by Alphabetical Order" />
        </MenuItem>
        <MenuItem Header="_Help">
          <MenuItem x:Name="InfoMenu" Header="_About" />
        </MenuItem>
      </Menu>
      <Grid DockPanel.Dock="Bottom" Margin="8,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="StatusLabel" Text="Ready" VerticalAlignment="Center" Grid.Column="0" />
        <TextBlock x:Name="ModifiedLabel" Text="" Margin="8,0" VerticalAlignment="Center" Grid.Column="1"
                   Foreground="#FF8800" FontWeight="Bold" />
        <ProgressBar x:Name="ProgressBar" Grid.Column="2" Minimum="0" Maximum="100" Value="0"
                     VerticalAlignment="Center" Height="16" />
      </Grid>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="2*" MinHeight="200" />
          <RowDefinition Height="4" />
          <RowDefinition Height="*" MinHeight="100" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="8,8,8,4" BorderBrush="#40808080" BorderThickness="1" CornerRadius="4">
          <TreeView x:Name="TreeView" />
        </Border>
        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="Transparent" />
        <Border Grid.Row="2" Margin="8,4,8,8" BorderBrush="#40808080" BorderThickness="1" CornerRadius="4">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Log" FontWeight="SemiBold" Margin="8,4" Opacity="0.6" />
            <TextBox x:Name="LogTextBox"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
          </DockPanel>
        </Border>
      </Grid>
    </DockPanel>
    <Canvas x:Name="DragOverlay" IsHitTestVisible="False" />
  </Panel>
</Window>